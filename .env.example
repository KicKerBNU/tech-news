# Anthropic (required for the digest agent)
ANTHROPIC_API_KEY=

# Honeycomb / OpenTelemetry (optional — tracing disabled if unset)
HONEYCOMB_API_KEY=
OTEL_SERVICE_NAME=signal-news-digest
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io

# GitHub — backend commits digests back to the repo (Railway)
# Fine-grained PAT with Contents: read and write on the repo
GITHUB_TOKEN=
GITHUB_REPO=KicKerBNU/tech-news
GITHUB_BRANCH=master

# Backend scheduler (Railway)
CRON_SCHEDULE=0 8 * * *
# Protect POST /api/digest/run — generate with: openssl rand -base64 32
CRON_SECRET=
PORT=3000

# Newsletter — Resend (subscribers + email delivery, no database needed)
RESEND_API_KEY=
# POC / sandbox (no domain): use Resend's test sender. You can only send TO the email
# you signed up to Resend with. For production, verify a domain and change this.
RESEND_FROM_EMAIL=SIGNAL <onboarding@resend.dev>
# Random secret for signed unsubscribe links — generate with: openssl rand -base64 32
UNSUBSCRIBE_SECRET=

# Public site URL (used in emails for links/unsubscribe)
SITE_URL=https://signal-news-agent.netlify.app

# Telegram (optional — posts daily digest to a group via bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_THREAD_ID=   # only for topic groups

# Netlify Functions (set in Netlify dashboard):
# RESEND_API_KEY, UNSUBSCRIBE_SECRET
